# ──────────────────────────────────────────────────────────────────────
# Configuración del Visor de Planos (Vite)
# Vite carga automáticamente el archivo según el modo:
#   .env.development  →  `npm run dev`  /  `npm run build:dev`
#   .env.production   →  `npm run build` (o build:prod)
# Solo las variables con prefijo VITE_ se incluyen en el build del frontend.
# ──────────────────────────────────────────────────────────────────────

# Base del servicio ORDS de APEX (host + schema). Lo ÚNICO que cambia
# entre entornos. NO incluyas el módulo ni el endpoint (van fijos en config.ts).
#   dev  → https://dev.aicsacorp.com/ords/safws
#   prod → https://prod.aicsacorp.com/ords/safws
# Déjala relativa (/ords/safws) si el visor vive en el MISMO dominio que APEX.
VITE_ORDS_BASE=https://dev.aicsacorp.com/ords/safws

# Origen del portal APEX aceptado en postMessage (seguridad).
VITE_APEX_ORIGIN=https://dev.aicsacorp.com
