# Containerfile — API REST del Visor de Planos (Express + node-oracledb thin)
# Build:  podman build -t planos-api:1.0 -f server/Containerfile server/
FROM node:20-slim

# Crear usuario no-root explícito (uid alto, fuera de rangos del host)
RUN useradd --system --uid 10001 --create-home appuser

WORKDIR /app

# Instalar solo dependencias de producción (capa cacheable)
COPY package.json ./
RUN npm install --omit=dev && npm cache clean --force

# Código del API
COPY server.js ./
COPY routes/ ./routes/
COPY xfdf-store.js ./

# Directorio de XFDF en disco (se monta un volumen encima en runtime)
RUN mkdir -p /data/xfdf && chown -R 10001:10001 /data /app
ENV XFDF_DIR=/data/xfdf

USER 10001
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:3000/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "server.js"]
