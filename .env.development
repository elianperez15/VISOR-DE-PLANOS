# Entorno DESARROLLO — se carga con `vite` (dev) y `vite build --mode development`
# ORDS relativo (mismo origen que el visor) → sin CORS. nginx reenvía /ords/ a
# https://dev.aicsacorp.com/ords/ (ver bloque location /ords/ en server/nginx-ords.conf).
VITE_ORDS_BASE=/ords/safws
VITE_APEX_ORIGIN=https://dev.aicsacorp.com
